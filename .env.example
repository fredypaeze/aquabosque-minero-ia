# Copia este archivo como ".env" y completa los valores reales.
# ".env" nunca se versiona (ver .gitignore).

# Ruta base de datos locales (opcional, por defecto usa ./data)
AQUABOSQUE_DATA_DIR=./data

# Credenciales de APIs externas (a definir cuando se elijan las fuentes de datos)
# EJEMPLO_API_KEY=
# EJEMPLO_API_SECRET=

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
