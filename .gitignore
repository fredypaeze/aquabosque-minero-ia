# Entorno virtual
venv/
.venv/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/

# Datos (no versionar datos pesados o crudos)
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Salidas generadas
outputs/figures/*
outputs/reports/*
!outputs/figures/.gitkeep
!outputs/reports/.gitkeep

# Notebooks checkpoints
.ipynb_checkpoints/

# Variables de entorno / credenciales
.env
*.env.local

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude
.claude/settings.local.json
